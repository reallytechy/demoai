# ============================================================
# DemoAI Backend — Configuration Template
# Copy to .env and fill in your values. NEVER commit .env.
# ============================================================

# --- App ---
APP_ENV=development
APP_DEBUG=true

# --- CORS ---
CORS_ALLOWED_ORIGINS=http://localhost:5173

# --- Supabase ---
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# --- LLM Provider (openrouter | openai) ---
LLM_PROVIDER=openrouter

# --- OpenRouter (default — cheap/free models at https://openrouter.ai) ---
OPENROUTER_API_KEY=sk-or-REPLACE_ME
OPENROUTER_MODEL=google/gemini-2.0-flash-001
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
#
# Other cheap models to try:
#   google/gemini-2.0-flash-001       ~$0.10/M tokens (fast, good tool use)
#   meta-llama/llama-4-scout-17b-16e-instruct:free  (free!)
#   google/gemma-3-4b-it:free          (free, smaller)
#   deepseek/deepseek-chat-v3-0324    ~$0.14/M tokens (strong reasoning)
#   anthropic/claude-3.5-haiku         ~$0.80/M tokens (great quality)

# --- OpenAI (optional, only if LLM_PROVIDER=openai) ---
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small

# --- LangSmith Observability ---
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=lsv2_REPLACE_ME
LANGCHAIN_PROJECT=demoai

# --- Agents ---
AGENT_MAX_ITERATIONS=15
AGENT_TEMPERATURE=0.1
AGENT_TIMEOUT_SECONDS=120

# --- Session ---
SESSION_TTL_HOURS=24
MAX_MEMORY_MESSAGES=50

# --- Documents ---
MAX_UPLOAD_SIZE_MB=10
ALLOWED_FILE_TYPES=pdf,csv,json,xlsx
